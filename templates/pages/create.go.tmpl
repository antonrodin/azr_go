{{ template "app" . }}

{{ define "content" }}
<h1>Create Page</h1>
<form action="/pages/store" method="POST">

    <div>
        <label for="title">Title</label>
        <input type="text" name="title" placeholder="Awesome Title"/>
    </div>


    <div>
        <label for="slug">Slug</label>
        <input type="text" name="slug" placeholder="awesome-title"/>
    </div>

    
    <div>
        <label for="content">Content</label>
        <textarea rows="10" cols="20" name="content">

        </textarea>
    </div>
    
    <div>
        <button type="submit">Crear</button>
    </div>
    
</form>
{{ end }}