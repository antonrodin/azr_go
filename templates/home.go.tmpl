{{ template "app" . }}

{{ define "metadata"}}
<title>{{ .MetaTitle }}</title>
<meta name="description" content="{{ .MetaDescription }}" />
<meta name="robots" content="all" />

<link rel="canonical" href="https://azr.es{{ .Path }}" />
<link rel="alternate" hreflang="es" href="https://azr.es/" />
<link rel="alternate" hreflang="en" href="https://azr.es/en" />
<link rel="alternate" hreflang="ru" href="https://azr.es/ru" />
<link rel="alternate" hreflang="x-default" href="https://azr.es/" />

<meta property="og:url" content="https://azr.es{{ .Path }}" />
<meta property="og:type" content="website" />
<meta property="og:title" content="{{ .OgTitle }}" />
<meta property="og:description" content="{{ .OgDescription }}" />
<meta property="og:image" content="/public/img/azr.jpg" />
{{ end }}

{{ define "content" }}

<main class="page">
    <div class="grid">

        <!-- Columna 1: Branding -->
        <aside class="brand">
            <div class="monogram">AZR</div>
            <picture>
                <source srcset="/public/img/azr.webp" type="image/webp">
                <img src="/public/img/azr.jpg" alt="Antón Zekeriev Rodin" class="photo" width="1200" height="900">
            </picture>
            <h1>Antón Zekeriev Rodin</h1>
            <ul class="claims">
                <li>{{ .ClaimFather }}</li>
                <li>{{ .ClaimSWE }}</li>
                <li>{{ .ClaimAI }} <span class="aside">{{ .ClaimAIAside }}</span>.</li>
                <li>{{ .ClaimWorks }} <span class="aside">{{ .ClaimWorksAside }}</span>.</li>
            </ul>
            <ul class="social">
                <li><a href="https://github.com/antonrodin" target="_blank" rel="noopener">GitHub</a></li>
                <li><a href="https://www.youtube.com/c/AZRMedia" target="_blank" rel="noopener">YouTube</a></li>
                <li><a href="https://www.linkedin.com/in/azrodin/" target="_blank" rel="noopener">LinkedIn</a></li>
                <li><a href="https://www.azrodin.com/" target="_blank" rel="noopener">Blog</a></li>
                <li><a href="mailto:azr@azr.es">azr@azr.es</a></li>
            </ul>
            <nav class="langs" aria-label="Idioma">
                <a href="/" {{ if eq .Lang "es" }}class="active" aria-current="true"{{ end }}>ES</a>
                <a href="/en" {{ if eq .Lang "en" }}class="active" aria-current="true"{{ end }}>EN</a>
                <a href="/ru" {{ if eq .Lang "ru" }}class="active" aria-current="true"{{ end }}>RU</a>
            </nav>
        </aside>

        <!-- Columna 2: Skills -->
        <section class="skills">
            <h2>{{ .SkillsHeading }}</h2>
            <p class="lead-note">{{ .SkillsNote }}</p>

            <div class="skill">
                <h3>{{ .Skill1Title }} <span class="aside">{{ .Skill1Aside }}</span></h3>
                <p>{{ .Skill1Body }}</p>
            </div>

            <div class="skill">
                <h3>{{ .BackendTitle }}</h3>
                <p>{{ .BackendBody }}</p>
            </div>

            <div class="skill">
                <h3>{{ .DevOpsTitle }}</h3>
                <p>{{ .DevOpsBody }} <span class="aside">{{ .DevOpsAside }}</span>.</p>
            </div>

            <div class="skill">
                <h3>{{ .FrontendTitle }}</h3>
                <p>{{ .FrontendBody }}</p>
            </div>

            <div class="skill">
                <h3>{{ .AITitle }}</h3>
                <p>{{ .AIBody }} <span class="aside">{{ .AIAside }}</span>.</p>
            </div>

            <div class="skill">
                <h3>{{ .OtherTitle }}</h3>
                <p>{{ .OtherBody }} <span class="aside">{{ .OtherAside }}</span>.</p>
            </div>
        </section>

    </div>

    <p class="colophon">
        {{ .ColophonPre }}
        <a href="https://claude.com/claude-code" target="_blank" rel="noopener">Claude Code</a>{{ .ColophonPost }}
    </p>
</main>

{{ end }}
