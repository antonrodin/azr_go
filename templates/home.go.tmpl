{{ template "app" . }}

{{ define "metadata"}}
<title>Antón Zekeriev Rodin — Ingeniero del Software</title>
<meta name="description" content="Antón Zekeriev Rodin. Padre, ingeniero del software. Hago cosas que funcionan. Go, TypeScript, JavaScript, PHP y lo que haga falta." />
<meta name="robots" content="all" />

<meta property="og:url" content="https://azr.es/" />
<meta property="og:type" content="website" />
<meta property="og:title" content="Antón Zekeriev Rodin — Ingeniero del Software" />
<meta property="og:description" content="Padre. Ingeniero del software. Hago cosas que funcionan." />
